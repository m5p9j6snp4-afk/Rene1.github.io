<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rene 的社交留言板</title>
    <!-- 引入社交媒体流评论区核心样式 -->
    <link rel="stylesheet" href="https://unpkg.com/@waline/client@v3/dist/waline.css" />
    <style>
        body { font-family: Arial, sans-serif; background-color: #f4f4f9; margin: 0; padding: 15px; display: flex; justify-content: center; }
        .container { background: white; padding: 25px; border-radius: 15px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); max-width: 450px; width: 100%; box-sizing: border-box; }
        .back-btn { display: inline-block; margin-bottom: 15px; color: #007bff; text-decoration: none; font-weight: bold; font-size: 14px; }
        h2 { margin-top: 0; color: #333; border-bottom: 2px solid #28a745; padding-bottom: 8px; font-size: 20px; }
        p.subtitle { color: #666; font-size: 13px; margin-bottom: 20px; }
        
        /* 深度定制小红书/微博社交风，迎合你原本的绿色调 */
        :root {
            --waline-theme-color: #28a745 !important;
            --waline-active-color: #1e7e34 !important;
        }
        .wl-power { display: none !important; } /* 保持界面干净 */
    </style>
</head>
<body>

    <div class="container">
        <!-- 点击完美退回原装主页 -->
        <a href="index.html" class="back-btn">⬅ 返回主页</a>
        <h2>💬 Rene 的动态朋友圈留言板</h2>
        <p class="subtitle">在这里像刷微博、朋友圈一样盖楼、点赞和吐槽吧！</p>
        
        <!-- 朋友圈评论区挂载点 -->
        <div id="waline"></div>
    </div>

    <!-- 社交评论组件核心脚本 -->
    <script type="module">
        import { init } from 'https://unpkg.com/@waline/client@v3/dist/waline.js';

        init({
            el: '#waline',
            // 部署好的极速公共社交数据库，直接可以用
            serverURL: 'https://waline-comment-demo.vercel.app', 
            placeholder: '说点什么吧，支持互相点赞和盖楼回复...',
            emoji: [
                'https://unpkg.com/@waline/emojis@1.2.0/weibo', // 纯正微博表情包
                'https://unpkg.com/@waline/emojis@1.2.0/bilibili' // 附带B站萌系表情
            ],
            dark: false,
            pageSize: 8,
        });
    </script>
</body>
</html>
